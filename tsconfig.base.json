{
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "preserve",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@storeos/ui": ["./layers/ui/index.ts"],
      "@storeos/ui/*": ["./layers/ui/*"],
      "@storeos/core": ["./layers/core/index.ts"],
      "@storeos/core/*": ["./layers/core/*"]
    }
  }
}
