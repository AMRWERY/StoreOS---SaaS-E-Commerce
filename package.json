{
  "name": "storeos",
  "private": true,
  "scripts": {
    "dev:web": "turbo run dev --filter=@storeos/web",
    "dev:storefront": "turbo run dev --filter=@storeos/storefront",
    "build": "turbo run build --concurrency=1",
    "build:web": "turbo run build --filter=@storeos/web",
    "build:storefront": "turbo run build --filter=@storeos/storefront",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.63",
    "@iconify-json/ph": "^1.2.2",
    "@types/node": "^25.5.0",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.28.1"
}
